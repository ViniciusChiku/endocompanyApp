# Firebase Configurações (Exemplo - Substitua com seus dados)
VITE_FIREBASE_API_KEY=sua_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=seu_auth_domain_aqui
VITE_FIREBASE_PROJECT_ID=seu_project_id_aqui
VITE_FIREBASE_STORAGE_BUCKET=seu_storage_bucket_aqui
VITE_FIREBASE_MESSAGING_SENDER_ID=seu_messaging_sender_id_aqui
VITE_FIREBASE_APP_ID=seu_app_id_aqui
VITE_FIREBASE_MEASUREMENT_ID=seu_measurement_id_aqui

# Firebase App Check & reCAPTCHA Enterprise
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=sua_chave_site_recaptcha_aqui
# Opcional: Token de depuração gerado no Firebase Console para testes locais em localhost
VITE_APPCHECK_DEBUG_TOKEN=seu_token_de_debug_local_aqui
